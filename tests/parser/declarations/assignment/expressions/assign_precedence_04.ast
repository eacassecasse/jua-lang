Program
├─── VariableDeclaration
│    ├─── mutable: true
│    └─── name: value
└─── AssignmentStatement
     ├─── target: value
     └─── BinaryExpression
          ├─── operator: AND
          ├─── BinaryExpression
          │    ├─── operator: EQUAL
          │    ├─── IntegerLiteral
          │    │    └─── value: 1
          │    └─── IntegerLiteral
          │         └─── value: 1
          └─── BooleanLiteral
               └─── value: true

