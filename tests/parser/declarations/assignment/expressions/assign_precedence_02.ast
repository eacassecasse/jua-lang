Program
├─── VariableDeclaration
│    ├─── mutable: true
│    └─── name: value
└─── AssignmentStatement
     ├─── target: value
     └─── BinaryExpression
          ├─── operator: MULTIPLY
          ├─── GroupingExpression
          │    └─── BinaryExpression
          │         ├─── operator: ADD
          │         ├─── IntegerLiteral
          │         │    └─── value: 1
          │         └─── IntegerLiteral
          │              └─── value: 2
          └─── IntegerLiteral
               └─── value: 3

